<div id="popup" class="popup">

<div class="popup-box">

<div class="gear">
⚙️
</div>

<h2>Welcome Engineering Portfolio</h2>

<p>Innovation • Technology • Engineering</p>

<button onclick="closePopup()">Enter</button>

</div>

</div>

.popup{
position:fixed;
top:0;
left:0;
width:100%;
height:100%;
background:rgba(0,0,0,.85);
display:flex;
justify-content:center;
align-items:center;
z-index:9999;
}

.popup-box{
background:rgba(20,20,40,.95);
padding:40px;
border-radius:20px;
text-align:center;
box-shadow:0 0 40px cyan;
animation:zoom .8s;
}

.gear{
font-size:90px;
color:#00E5FF;
animation:spin 4s linear infinite;
margin-bottom:20px;
}

@keyframes spin{
100%{
transform:rotate(360deg);
}
}

button{
padding:12px 35px;
background:#00E5FF;
border:none;
border-radius:40px;
font-size:18px;
cursor:pointer;
transition:.4s;
}

button:hover{
background:#FF9800;
transform:scale(1.08);
}

@keyframes zoom{
from{
transform:scale(.5);
opacity:0;
}
to{
transform:scale(1);
opacity:1;
}
}

function closePopup(){
document.getElementById("popup").style.display="none";
}

<section class="hero">

<h1>ENGINEERING PORTFOLIO</h1>

<p>Future Engineer • Innovation • Technology</p>

</section>

.hero{

height:100vh;

background:
linear-gradient(rgba(0,0,40,.6),rgba(0,0,40,.8)),
url(images/cover.jpg);

background-size:cover;

background-position:center;

display:flex;

justify-content:center;

align-items:center;

flex-direction:column;

color:white;

text-align:center;

}

.hero h1{

font-size:70px;

letter-spacing:5px;

text-shadow:0 0 20px cyan;

}

.hero p{

font-size:25px;

color:#00E5FF;

}

<div class="gear-bg">⚙</div>

.gear-bg{

position:fixed;

right:40px;

bottom:40px;

font-size:120px;

opacity:.08;

animation:spin 15s linear infinite;

color:#00E5FF;

}

.card{

background:rgba(255,255,255,.08);

backdrop-filter:blur(12px);

border:1px solid rgba(255,255,255,.2);

border-radius:20px;

transition:.4s;

}

.card:hover{

transform:translateY(-10px);

box-shadow:0 0 30px cyan;

}

nav{

background:rgba(5,15,40,.9);

backdrop-filter:blur(10px);

position:sticky;

top:0;

}

nav a:hover{

color:#00E5FF;

text-shadow:0 0 10px cyan;

}
